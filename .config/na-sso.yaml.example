# Copy to .config/na-sso.yaml. This strict YAML file owns password/key policy
# and the ordered target registry. Unknown fields are rejected at startup.
# Target IDs are durable database keys: use 2-64 lowercase letters, digits,
# underscores, or hyphens, starting with a letter. Do not rename IDs casually.

# Only schema version 1 is currently supported.
version: 1

# Managed-account password acceptance, generation, history, and expiry policy.
password_policy:
  min_length: 14                 # 8-1024
  max_length: 128                # 8-4096; must be >= min_length
  require_lowercase: true
  require_uppercase: true
  require_digit: true
  require_symbol: true
  max_repeated_characters: 3     # 1-128; use null to disable this check
  max_numeric_sequence: 3        # 2-32; use null to disable this check
  min_identity_distance: 4       # 1-128 and <= max_length; null disables
  reject_identity_terms: true    # Reject username/email/display-name terms
  history_size: 3                # 0-100 previous hashes; 0 disables history
  expires_after_days: 90         # 1-3650; use null for no password expiry
  expiry_acknowledgement_mode: grace # disabled, renewal, or grace
  expiry_acknowledgement_grace_days: 14 # 1-3650; used only by grace mode
  expiry_acknowledgement_limit: 1 # 1-100 per password; null allows unlimited

# User SSH-key enrollment policy.
ssh_key_policy:
  allowed_algorithms: [ed25519, rsa] # Non-empty, unique; ed25519 and/or rsa
  rsa_min_bits: 3072                  # 2048-16384
  browser_generation: true            # Prefer private-key generation in browser
  allow_server_fallback: false        # Explicit compatibility flow; private key returned once
  default_expiry_days: 365            # 1-3650, or null for no default expiry
  max_expiry_days: 730                # 1-3650, or null for no maximum

# Read-only target-local account discovery. Remote deletion is separately
# Root-approved and disabled until deployment recovery policy is ready.
unmanaged_account_policy:
  enabled: true
  max_accounts_per_target: 1000       # 1-10000; discovery result bound
  ssh_min_uid: 1000                   # Lower Unix UIDs are treated as system accounts
  excluded_usernames: [root, nobody, sync, shutdown, halt]
  excluded_prefixes: ["_", "systemd-", "svc-"]
  allow_removal: false                # Requires Root two-step approval when true

# Managed-user support path shown only when assigned access needs operator help.
support_policy:
  label: Contact identity operations
  url: null                           # https://, http://, or mailto:; null shows label only
  guidance: Share your username and target name; never send passwords or private keys.

# Audit exports are page-bounded; retention removes events but never correlated
# lifecycle operation or target-attempt records. Use null to retain events forever.
audit_policy:
  retention_days: 365              # 1-36500, or null
  export_page_size: 500            # 25-5000 rows per downloaded page

# Scheduled reconciliation performs read-only discovery only. It never repairs
# or deletes without an operator opening a saved preview and approving it.
reconciliation_policy:
  enabled: false
  interval_seconds: 3600           # 60-2592000
  scan_seconds: 60                 # 5-3600
  retry_base_seconds: 60           # 5-86400
  retry_max_seconds: 3600          # 5-604800; >= retry_base_seconds
  max_attempts: 5                  # 1-20 failed read attempts
  max_users_per_run: 100           # 1-1000

# Lifecycle scheduling and access-review defaults. Per-account owner, reason,
# timing, inactivity window, and end action are managed in the Users UI.
lifecycle_automation_policy:
  scan_seconds: 60                 # 5-3600
  default_review_interval_days: 90 # 1-3650 after a retain decision
  reminder_days_before_due: 7      # 0-365
  max_review_accounts: 1000        # 1-5000 per campaign preview

# The versioned automation API uses the same capability checks, correlated
# operations, audit records, previews, and approvals as the browser UI.
automation_api_policy:
  enabled: true
  requests_per_minute: 120         # 10-10000 per authenticated principal/IP
  max_page_size: 100               # 25-500 records
  idempotency_retention_hours: 24  # 1-720
  default_token_days: 90           # 1-3650
  max_token_days: 365              # 1-3650; >= default_token_days

# Administrative MFA affects NA-SSO operator login only; target logins and
# managed-user target credentials are unchanged. Set explicit WebAuthn values
# behind a reverse proxy. With required=true, operators must enrol before use.
admin_mfa_policy:
  required: true
  allowed_methods: [webauthn, totp]
  issuer: NA-SSO
  rp_id: sso.example.lan
  expected_origin: https://sso.example.lan
  reauthentication_minutes: 10

# Signed outbound notifications use a durable retry queue and contain only a
# small allowlisted payload. Endpoint secrets may be exact ${ENV_NAME} values.
notification_policy:
  enabled: false
  persistent_failure_attempts: 3
  max_attempts: 5
  retry_base_seconds: 30
  retry_max_seconds: 3600
  delivery_scan_seconds: 10
  endpoints: []
  # - id: identity_alerts
  #   url: https://automation.example.lan/hooks/na-sso
  #   secret: ${IDENTITY_ALERTS_WEBHOOK_SECRET}
  #   enabled: true
  #   events: [sync.persistent_failure, password.expired, lifecycle.completed, approval.completed, access_review.reminder]

# Target management credentials should normally be saved in the Targets UI.
# The commented credential fields below show the supported environment-backed
# alternative. A ${NAME} value must be the entire YAML scalar and NAME must
# exist in .config/.env. Never place literal production secrets in this file.
targets:
  # OPNsense Auth User API target.
  - id: firewall_primary
    type: opnsense
    display_name: Primary firewall
    enabled: true
    base_url: https://opnsense.example.lan # Server root; no trailing API path
    verify_tls: true
    default_groups: [vpn-users]          # Existing safe group identifiers
    # api_key: ${OPNSENSE_PRIMARY_API_KEY}
    # api_secret: ${OPNSENSE_PRIMARY_API_SECRET}

  # Nexus Repository local-user Security API target.
  - id: nexus_primary
    type: nexus
    display_name: Nexus Repository
    enabled: true
    base_url: https://nexus.example.lan
    verify_tls: true
    default_roles: [nx-anonymous]        # Existing Nexus role IDs
    # admin_user: ${NEXUS_PRIMARY_ADMIN_USER}
    # admin_password: ${NEXUS_PRIMARY_ADMIN_PASSWORD}

  # Nextcloud OCS Provisioning API target.
  - id: cloud_primary
    type: nextcloud
    display_name: Nextcloud
    enabled: true
    base_url: https://nextcloud.example.lan
    verify_tls: true
    default_groups: [employees]          # Existing safe group identifiers
    # admin_user: ${NEXTCLOUD_PRIMARY_ADMIN_USER}
    # admin_password: ${NEXTCLOUD_PRIMARY_ADMIN_PASSWORD}

  # GitLab Self-Managed administrator Users API target.
  - id: gitlab_primary
    type: gitlab
    display_name: GitLab
    enabled: true
    base_url: https://gitlab.example.lan
    verify_tls: true
    # api_token: ${GITLAB_PRIMARY_API_TOKEN}

  # Gitea administrator Users API target.
  - id: gitea_primary
    type: gitea
    display_name: Gitea
    enabled: true
    base_url: https://gitea.example.lan
    verify_tls: true
    # api_token: ${GITEA_PRIMARY_API_TOKEN}

  # Immich administrator Users API target.
  - id: immich_primary
    type: immich
    display_name: Immich
    enabled: true
    base_url: https://immich.example.lan
    verify_tls: true
    # api_token: ${IMMICH_PRIMARY_API_TOKEN}

  # Jenkins built-in local security realm. Core Jenkins cannot disable users;
  # unassignment is reported as unsupported instead of deleting the account.
  - id: jenkins_primary
    type: jenkins
    display_name: Jenkins
    enabled: true
    base_url: https://jenkins.example.lan
    verify_tls: true
    # admin_user: ${JENKINS_PRIMARY_ADMIN_USER}
    # api_token: ${JENKINS_PRIMARY_API_TOKEN}

  # SSH-managed Unix target. Duplicate this entry for each host.
  - id: ssh_debian
    type: ssh
    display_name: Debian shell
    enabled: true
    host: shell.example.lan
    port: 22                             # 1-65535
    host_key_sha256: SHA256:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
    platform: debian                     # debian, ubuntu, rhel, or rocky
    allow_relaxed_usernames: false
    mode: password_and_key               # password, key, or password_and_key
    default_groups: [developers]         # Existing supplementary groups
    # management_user: ${SSH_PRIMARY_MANAGEMENT_USER}
    # Use a password, one private-key source, or a password plus one key source:
    # management_password: ${SSH_PRIMARY_MANAGEMENT_PASSWORD}
    # management_private_key: ${SSH_PRIMARY_MANAGEMENT_PRIVATE_KEY}
    # management_private_key_file: /run/secrets/ssh_management_key
