# Copy this file to .config/.env. It configures the normal `na-sso` container.
# Do not commit .config/.env; it contains the application encryption key and
# bootstrap password. Target credentials should normally be entered through the
# Targets UI, where they are encrypted in SQLite.

# Required: stable secret used for session signing and encrypted stored values.
# Generate a long random value and back it up with the database volume.
NA_SSO_SECRET_KEY=replace-with-a-long-random-secret

# Creates the first local administrator only when the database has no admin.
# Changing these values later does not rename the account or rotate its password.
NA_SSO_ADMIN_USERNAME=admin
NA_SSO_ADMIN_BOOTSTRAP_PASSWORD=replace-before-first-start

# Container path for SQLite. Keep this under /data for the persistent volume.
NA_SSO_DATABASE_PATH=/data/na-sso.db

# Automatic recovery timing in seconds: scan interval, initial retry delay, and
# exponential-backoff ceiling.
NA_SSO_RETRY_SCAN_SECONDS=5
NA_SSO_RETRY_BASE_SECONDS=5
NA_SSO_RETRY_MAX_SECONDS=300

# docker-compose.yaml sets NA_SSO_CONFIG_FILE=/config/na-sso.yaml and mounts
# .config/na-sso.yaml there read-only. Do not override it in this file.

# Optional alternative to UI-managed target credentials: uncomment variables
# here and matching ${VARIABLE_NAME} fields in na-sso.yaml. Avoid this mode
# unless deployment automation owns the secrets and environment file securely.
# OPNSENSE_PRIMARY_API_KEY=
# OPNSENSE_PRIMARY_API_SECRET=
# NEXUS_PRIMARY_ADMIN_USER=admin
# NEXUS_PRIMARY_ADMIN_PASSWORD=
# NEXTCLOUD_PRIMARY_ADMIN_USER=admin
# NEXTCLOUD_PRIMARY_ADMIN_PASSWORD=
# SSH_PRIMARY_MANAGEMENT_USER=provisioner
# SSH_PRIMARY_MANAGEMENT_PASSWORD=
# SSH_PRIMARY_MANAGEMENT_PRIVATE_KEY=
