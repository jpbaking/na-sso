# Copy to .config/.env and fill in. compose-helper passes this file to docker compose.

# --- core ---
ONEAUTH_SECRET_KEY=generate-a-long-random-string
ONEAUTH_ADMIN_USERNAME=admin
ONEAUTH_ADMIN_BOOTSTRAP_PASSWORD=change-me-on-first-login
ONEAUTH_DATABASE_PATH=/data/oneauth.db

# --- OPNsense ---
ONEAUTH_OPNSENSE_ENABLED=false
ONEAUTH_OPNSENSE_BASE_URL=https://opnsense.example.lan
ONEAUTH_OPNSENSE_API_KEY=
ONEAUTH_OPNSENSE_API_SECRET=
ONEAUTH_OPNSENSE_VERIFY_TLS=true

# --- Nexus Repository ---
ONEAUTH_NEXUS_ENABLED=false
ONEAUTH_NEXUS_BASE_URL=https://nexus.example.lan
ONEAUTH_NEXUS_ADMIN_USER=admin
ONEAUTH_NEXUS_ADMIN_PASSWORD=
ONEAUTH_NEXUS_DEFAULT_ROLES=nx-anonymous

# --- Nextcloud ---
ONEAUTH_NEXTCLOUD_ENABLED=false
ONEAUTH_NEXTCLOUD_BASE_URL=https://nextcloud.example.lan
ONEAUTH_NEXTCLOUD_ADMIN_USER=admin
ONEAUTH_NEXTCLOUD_ADMIN_PASSWORD=
